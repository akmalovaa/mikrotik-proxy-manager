# Base settings
LOG_LEVEL="DEBUG"

# MikroTik RouterOS 
MIKROTIK_HOST="192.168.88.1"
MIKROTIK_USER="user"
MIKROTIK_PASSWORD="password"
# LOG_JSON="true"  # structured JSON logs (matches Traefik's log.format)

# Traefik
TRAEFIK_CONFIGS_PATH="./configs"
# TLS_CERT_RESOLVER — leave empty to let routers inherit the resolver (and any
# wildcard `domains` block) from the entryPoint-level `http.tls` config in your
# static traefik.yml. Set it only if you want per-router cert resolvers.
# TLS_CERT_RESOLVER="cloudflare"
# CF_DNS_API_TOKEN="your_cloudflare_api_token" # Uncomment if using Cloudflare DNS challenge
